# auth-bus — renovação automática do token ML (preferido; configure no Railway)
AUTH_BUS_URL=https://auth-bus.zioncompanyai.com.br
AUTH_BUS_API_KEY=your_auth_bus_api_key_here
# Fallback estático — usado apenas quando AUTH_BUS_URL/AUTH_BUS_API_KEY não estão configurados
ML_USER_ACCESS_TOKEN=your_mercadolibre_access_token_here
ALIEXPRESS_APP_KEY=your_app_key_here
ALIEXPRESS_APP_SECRET=your_app_secret_here
ALIEXPRESS_TRACKING_ID=your_tracking_id_here
# Credenciais para scraping autenticado (opcional — melhora limites de acesso)
ALIEXPRESS_USERNAME=
ALIEXPRESS_PASSWORD=
TELEGRAM_BOT_TOKEN=your_bot_token_here
MC_API_KEY=your_mc_api_key_here
